# ══════════════════════════════════════════════════════════════════════════════
# UVerify Sandbox — Environment Configuration
#
# Copy this file to .env before running ./start.sh:
#   cp .env.example .env
#
# Fill in your own mnemonic phrases below. Use freshly generated wallets —
# NEVER reuse mainnet or preprod wallets here.
# ══════════════════════════════════════════════════════════════════════════════

PORT=9090

# Spring profiles: 'devnet' activates the local-devnet YACI store config,
# 'postgres' switches the database to PostgreSQL.
SPRING_ACTIVE_PROFILES=devnet,postgres

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://postgres:5432/uverify
DB_USERNAME=uverify
DB_PASSWORD=sandbox_password

# ── Cardano network ───────────────────────────────────────────────────────────
# 'PREPROD' keeps testnet address encoding (network ID 0), which is also used
# by the local devnet.
CARDANO_NETWORK=PREPROD

# ── Cardano backend (yaci node-app Blockfrost-compatible API) ─────────────────
# The backend uses this to query UTxOs and submit transactions.
# The yaci-node container exposes a Blockfrost-compatible REST API on port 8080.
CARDANO_BACKEND_TYPE=blockfrost
BLOCKFROST_PROJECT_ID=localtest
BLOCKFROST_BASE_URL=http://yaci-node:8080/api/v1/

# ── Service account ───────────────────────────────────────────────────────────
# Pays for the INIT and library-deploy transactions during bootstrap.
# SERVICE_USER_ADDRESS is derived from the mnemonic and filled in automatically
# by bootstrap.ts on the first run. Leave it blank initially.
SERVICE_ACCOUNT_MNEMONIC=
SERVICE_USER_ADDRESS=

# ── Facilitator (optional) ────────────────────────────────────────────────────
# Signs REST authentication challenges. Generated automatically if omitted.
FACILITATOR_ACCOUNT_MNEMONIC=

# ── Fee receiver ──────────────────────────────────────────────────────────────
FEE_RECEIVER_MNEMONIC=
FEE_RECEIVER_PARTNER_ADDRESS=

# ── Faucet ────────────────────────────────────────────────────────────────────
# The backend faucet funds example wallets on their first run.
# No real ADA involved — funded by the local devnet.
FAUCET_ENABLED=true
FAUCET_MNEMONIC=
FAUCET_UTXO_COUNT=3
FAUCET_UTXO_AMOUNT_LOVELACE=10000000
FAUCET_COOLDOWN_MS=30000

# ── Proxy contract reference ──────────────────────────────────────────────────
# Left blank on first run. bootstrap.ts populates these automatically after
# the INIT transaction is submitted and the backend is restarted.
PROXY_TX_HASH=
PROXY_OUTPUT_INDEX=1

# ── Connected Goods extension (optional) ──────────────────────────────────────
CONNECTED_GOODS_EXTENSION_ENABLED=false
CONNECTED_GOODS_SERVICE_WALLET_MNEMONIC=
CONNECTED_GOODS_SERVICE_WALLET_ADDRESS=
CONNECTED_GOODS_ENCRYPTION_SALT=sandbox_salt_1234

# ── Tadamon extension (disabled for sandbox) ──────────────────────────────────
TADAMON_EXTENSION_ENABLED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=*

# ── YACI Store sync ───────────────────────────────────────────────────────────
# Sync settings (slot, hash, protocol-magic) are configured in
# application-devnet.yml — do not override here.
YACI_STORE_AUTO_START=true
